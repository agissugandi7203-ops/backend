# Port server NestJS berjalan
PORT=3000

# Kredensial Supabase (Wajib diisi)
# SUPABASE_URL: Dapatkan dari Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co

# SUPABASE_SERVICE_ROLE_KEY: Dapatkan dari Supabase Dashboard -> Project Settings -> API
# PENTING: Kunci ini memiliki akses bypass RLS. JANGAN PERNAH bocorkan ke Frontend/Mobile!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Kredensial Google Cloud Storage (GCS) - Diperlukan untuk Fitur 3
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=genesis-id-reports
GCS_KEY_FILE_PATH=secrets/gcs-key.json
